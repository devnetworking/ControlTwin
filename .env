# Application
APP_NAME=ControlTwin
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1

# JWT / Security
JWT_SECRET_KEY=change_me_super_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_BCRYPT_ROUNDS=12
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=15

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=controltwin
POSTGRES_USER=controltwin
POSTGRES_PASSWORD=controltwin

# InfluxDB
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=controltwin-influx-token
INFLUXDB_ORG=controltwin
INFLUXDB_BUCKET_REALTIME=ics_realtime
INFLUXDB_BUCKET_HISTORY=ics_history
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=adminadmin

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_DATAPOINTS=ics.datapoints
KAFKA_TOPIC_ALERTS=ics.alerts
KAFKA_TOPIC_EVENTS=ics.events

# MQTT
MQTT_BROKER_HOST=mqtt
MQTT_BROKER_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# pgAdmin (dev profile)
PGADMIN_DEFAULT_EMAIL=admin@controltwin.local
PGADMIN_DEFAULT_PASSWORD=admin
